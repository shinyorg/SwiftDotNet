<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <Nullable>enable</Nullable>
        <ImplicitUsings>enable</ImplicitUsings>
        <LangVersion>latest</LangVersion>
        <IsPackable>false</IsPackable>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.11.1"/>
        <PackageReference Include="xunit" Version="2.9.2"/>
        <PackageReference Include="xunit.runner.visualstudio" Version="2.8.2"/>
    </ItemGroup>

    <ItemGroup>
        <!-- Reference the plain net10.0 build of the core runtime (no platform head needed). -->
        <ProjectReference Include="..\..\src\SwiftDotNet\SwiftDotNet.csproj"/>
        <!-- The Skia self-drawing backend is pure C# + SkiaSharp (runs headless on macOS/Linux/Windows),
             so it can be driven directly in tests to exercise host-side patch application. -->
        <ProjectReference Include="..\..\src\SwiftDotNet.Skia\SwiftDotNet.Skia.csproj"/>
    </ItemGroup>

</Project>
